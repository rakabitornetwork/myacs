NODE_ENV=production
PORT=3000
APP_URL=https://myacs.teslatech.my.id

# Mode panel saja — CWMP tetap di GenieACS (bukan dual)
ACS_MODE=genieacs-panel

MONGODB_URI=mongodb://127.0.0.1:27017/myacs
GENIEACS_MONGODB_URI=mongodb://127.0.0.1:27017/genieacs

SESSION_SECRET=ganti-dengan-string-acak-panjang

GENIEACS_CWMP_URL=http://YOUR_VPS_IP:7547
GENIEACS_SYNC_INTERVAL=5

DEVICE_OFFLINE_MINUTES=15
UPLOAD_MAX_MB=100
