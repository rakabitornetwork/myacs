NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/myacs

SESSION_SECRET=myacs-dev-session-secret-change-in-production

# ACS_MODE: standalone | dual | genieacs-panel
ACS_MODE=standalone

# Untuk dual ACS di VPS (Opsi C):
# ACS_MODE=dual
# GENIEACS_MONGODB_URI=mongodb://127.0.0.1:27017/genieacs
# GENIEACS_CWMP_URL=http://your-vps:7547
# GENIEACS_SYNC_INTERVAL=5

CWMP_PATH=/cwmp
# URL ACS untuk CPE (ONU). Jika kosong → APP_URL + CWMP_PATH
# Contoh production CMHI: http://myacs.teslatech.my.id/cwmp
# CWMP_PUBLIC_URL=http://myacs.teslatech.my.id/cwmp
DEVICE_OFFLINE_MINUTES=15
UPLOAD_MAX_MB=100
